<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CFEFFF">

    <!-- ===== BASIC VIEW ===== -->

    <!-- Hàng nút tròn trên: Power - Mute - TV/AV -->
    <LinearLayout
        android:id="@+id/rowTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnPower"
            style="@style/Control_CircleButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:text="\uD83D\uDD0C"
            android:textSize="22sp"
            android:paddingTop="12dp"/>

        <Space android:layout_width="28dp" android:layout_height="1dp"/>

        <TextView
            android:id="@+id/btnMute"
            style="@style/Control_CircleButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:text="🔇"
            android:textSize="22sp"
            android:paddingTop="12dp"/>

        <Space android:layout_width="28dp" android:layout_height="1dp"/>

        <TextView
            android:id="@+id/btnTvAv"
            style="@style/Control_CircleButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:text="TV/AV"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Cột trái: Vol (pill) -->
    <LinearLayout
        android:id="@+id/pillVol"
        android:layout_width="72dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_pill"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/rowTop"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/btnVolUp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="+"
            android:textStyle="bold"
            android:textSize="22sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vol"
            android:textSize="16sp"
            android:layout_marginVertical="4dp"/>

        <TextView
            android:id="@+id/btnVolDown"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="−"
            android:textStyle="bold"
            android:textSize="22sp"/>
    </LinearLayout>

    <!-- Cột phải: CH (pill) -->
    <LinearLayout
        android:id="@+id/pillCh"
        android:layout_width="72dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_pill"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/pillVol"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="20dp">

        <TextView
            android:id="@+id/btnChUp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="▴"
            android:textSize="20sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CH"
            android:textSize="16sp"
            android:layout_marginVertical="4dp"/>

        <TextView
            android:id="@+id/btnChDown"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="▾"
            android:textSize="20sp"/>
    </LinearLayout>

    <!-- 2 nút tròn giữa: Menu & Exit -->
    <LinearLayout
        android:id="@+id/rowCenter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/pillVol"
        app:layout_constraintBottom_toBottomOf="@id/pillVol"
        app:layout_constraintStart_toEndOf="@id/pillVol"
        app:layout_constraintEnd_toStartOf="@id/pillCh">

        <TextView
            android:id="@+id/btnMenu"
            style="@style/Control_CircleButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:text="Menu"/>

        <Space android:layout_width="1dp" android:layout_height="16dp"/>

        <TextView
            android:id="@+id/btnExit"
            style="@style/Control_CircleButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:text="Exit"/>
    </LinearLayout>

    <!-- Dòng link: 123 (blue)  |  Menu (blue).  Không có 'More' -->
    <LinearLayout
        android:id="@+id/rowLinks"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/pillVol"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/link123"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:text="123"
            android:textColor="#1F6FE5"
            android:paddingHorizontal="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/linkMenu"
            style="@style/TextAppearance.Material3.BodyLarge"
            android:text="Menu"
            android:textColor="#1F6FE5"
            android:paddingHorizontal="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Nút nổi Home / Back (mờ) -->
    <TextView
        android:id="@+id/btnHome"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_fab_translucent"
        android:text="🏠"
        android:textSize="20sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/rowLinks"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="28dp"
        android:layout_marginTop="18dp"/>

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_fab_translucent"
        android:text="↩"
        android:textSize="20sp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/btnHome"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="28dp"/>

    <!-- D-pad tròn lớn -->
    <FrameLayout
        android:id="@+id/dpad"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="28dp"
        app:layout_constraintTop_toBottomOf="@id/btnHome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="1">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_dpad_outer"/>

        <TextView
            android:id="@+id/btnOk"
            android:layout_gravity="center"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/bg_circle_white"
            android:text="OK"
            android:textSize="22sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/btnUp"
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:layout_gravity="top|center_horizontal"
            android:gravity="center"
            android:text="▲"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/btnDown"
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:layout_gravity="bottom|center_horizontal"
            android:gravity="center"
            android:text="▼"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/btnLeft"
            android:layout_width="100dp"
            android:layout_height="120dp"
            android:layout_gravity="center_vertical|start"
            android:gravity="center"
            android:text="◀"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/btnRight"
            android:layout_width="100dp"
            android:layout_height="120dp"
            android:layout_gravity="center_vertical|end"
            android:gravity="center"
            android:text="▶"
            android:textSize="18sp"/>
    </FrameLayout>

    <!-- Gom nhóm BASIC để ẩn/hiện nhanh -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/groupBasic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="rowTop,pillVol,pillCh,rowCenter,rowLinks,btnHome,btnBack,dpad"/>

    <!-- ===== DIGITS VIEW (khi nhấn 123) ===== -->

    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/gridDigits"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:useDefaultMargins="true"
        app:alignmentMode="alignMargins"
        android:padding="16dp"
        android:visibility="gone"
        app:columnCount="3"
        app:layout_constraintTop_toBottomOf="@id/rowLinks"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Hàng 1 -->
        <TextView android:id="@+id/btnDigit1" style="@style/Control_CircleButton" android:text="1"/>
        <TextView android:id="@+id/btnDigit2" style="@style/Control_CircleButton" android:text="2"/>
        <TextView android:id="@+id/btnDigit3" style="@style/Control_CircleButton" android:text="3"/>

        <!-- Hàng 2 -->
        <TextView android:id="@+id/btnDigit4" style="@style/Control_CircleButton" android:text="4"/>
        <TextView android:id="@+id/btnDigit5" style="@style/Control_CircleButton" android:text="5"/>
        <TextView android:id="@+id/btnDigit6" style="@style/Control_CircleButton" android:text="6"/>

        <!-- Hàng 3 -->
        <TextView android:id="@+id/btnDigit7" style="@style/Control_CircleButton" android:text="7"/>
        <TextView android:id="@+id/btnDigit8" style="@style/Control_CircleButton" android:text="8"/>
        <TextView android:id="@+id/btnDigit9" style="@style/Control_CircleButton" android:text="9"/>

        <!-- Hàng 4: —/- , 0 , Back -->
        <TextView android:id="@+id/btnDash"  style="@style/Control_CircleButton" android:text="−/−−"/>
        <TextView android:id="@+id/btnDigit0" style="@style/Control_CircleButton" android:text="0"/>
        <TextView android:id="@+id/btnDigitBack" style="@style/Control_CircleButton" android:text="↩"/>
    </androidx.gridlayout.widget.GridLayout>

    <!-- Gom nhóm DIGITS -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/groupDigits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="gridDigits"/>

</androidx.constraintlayout.widget.ConstraintLayout>
